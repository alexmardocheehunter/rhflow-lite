# Server configurations
PORT=3000

# Database configurations (Supabase connection parameters)
# DATABASE_URL: direct connection url (port 5432) used for Prisma migrations
DATABASE_URL="postgresql://postgres:[PASSWORD]@[HOST]:5432/postgres"

# DIRECT_URL: pooler connection url (port 6543) used in application production code
DIRECT_URL="postgresql://postgres.pool:[PASSWORD]@[HOST]:6543/postgres?pgbouncer=true"

# Supabase Client configurations
SUPABASE_URL="https://your-project-id.supabase.co"
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"

# Supabase Auth configuration
# JWT secret can be found in the Supabase Dashboard -> Settings -> API -> JWT Secret
SUPABASE_JWT_SECRET="your-supabase-jwt-secret"
